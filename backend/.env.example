# Copy this file to .env and fill in your actual values.
# The .env file must be placed in the backend/ directory.

# Gemini is used only for generation in /analyze
GEMINI_API_KEY=your_gemini_api_key_here

# Local embedding model configuration (InLegalBERT)
LOCAL_EMBEDDING_MODEL=law-ai/InLegalBERT
# Set to cpu/mps, leave blank for CPU default
EMBEDDING_DEVICE=
EMBEDDING_BATCH_SIZE=64
QUERY_EMBEDDING_PREFIX=
MODEL_CACHE_DIR=~/.cache/huggingface
USE_SAFETENSORS=true

# Retrieval and ingestion tuning
RETRIEVAL_TOP_K=5
INGEST_CHUNK_SIZE_WORDS=220
INGEST_CHUNK_OVERLAP_WORDS=40
